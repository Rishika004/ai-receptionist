generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Booking {
  id            Int      @id @default(autoincrement())
  name          String
  email         String
  date          String
  time          String
  googleEventId String
  createdAt     DateTime @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  message   String
  createdAt DateTime @default(now())
}
